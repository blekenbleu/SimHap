			<Style x:Name="LockToggle" TargetType="{x:Type ToggleButton}">
				<Setter Property="Content">
					<Setter.Value>
						<Image Source="C:\Users\demas\source\repos\SimHap\Resources\unlocked50x50.png" />
					</Setter.Value>
				</Setter>

				<Style.Triggers>
