                                    LostFocus="SuspensionMult_LostFocus"
                                    Maximum="2"
                                    Minimum="0"
                                    TickFrequency="0.1"
                                    ValueChanged="SuspensionMultAll_ValueChanged"
                                    Value="{Binding D.SuspensionMult}" />
                                <!--  all gamma  -->
                                <Slider
                                    x:Name="SuspensionGammaAll"
                                    Grid.Row="2"
                                    Grid.Column="2"
                                    Grid.ColumnSpan="2"
                                    Width="160"
                                    HorizontalAlignment="Center"
                                    GotFocus="SuspensionGammaAll_GotFocus"
                                    IsSnapToTickEnabled="True"
                                    LostFocus="SuspensionGammaAll_LostFocus"
                                    Maximum="2"
                                    Minimum="0"
                                    TickFrequency="0.1"
                                    ValueChanged="SuspensionGammaAll_ValueChanged"
                                    Value="{Binding D.SuspensionGammaAll}" />
                                <!--  game gamma  -->
                                <Slider
                                    x:Name="SuspensionGamma"
                                    Grid.Row="6"
                                    Grid.Column="2"
                                    Grid.ColumnSpan="2"
                                    Width="160"
                                    HorizontalAlignment="Center"
                                    GotFocus="SuspensionGamma_GotFocus"
                                    IsSnapToTickEnabled="True"
                                    LostFocus="SuspensionGamma_LostFocus"
                                    Maximum="2"
                                    Minimum="0"
                                    TickFrequency="0.1"
                                    ValueChanged="SuspensionGamma_ValueChanged"
                                    Value="{Binding D.SuspensionGamma}" />

                                <!--  reset button  -->
                                <Button
                                    x:Name="ButtonResetSuspension"
                                    Grid.Row="8"
                                    Grid.Column="0"
                                    Grid.ColumnSpan="4"
                                    Width="95"
                                    Height="30"
                                    BorderThickness="0"
                                    Click="ButtonResetSuspension_Click"
                                    FontFamily="roboto"
                                    FontSize="16"
                                    FontWeight="SemiBold"
                                    Foreground="White"
                                    Style="{StaticResource dMASSbutton}">
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        FontFamily="roboto"
                                        FontSize="16"
                                        Text="Reset" />
                                </Button>


                            </Grid>
                        </Expander>


                    </StackPanel>
                </ScrollViewer>

                <!--  status bar  -->
                <StatusBar
                    Grid.Row="1"
                    Margin="5,0,5,0"
                    Background="{DynamicResource Background}"
                    FontFamily="roboto"
                    FontSize="16"
                    Foreground="{DynamicResource Foreground}">
                    <!--  version number  -->
                    <StatusBarItem>
                        <TextBlock Name="Version" />
                    </StatusBarItem>
                    <!--  status message  -->
                    <StatusBarItem>
                        <TextBlock Text="{Binding D.LoadText, Mode=TwoWay}" />
                    </StatusBarItem>
                </StatusBar>
            </Grid>

        </Grid>
    </Border>
</UserControl>
